{
    "permissions": {
        "allow": [
            "Bash(awk:*)",
            "Bash(cat:*)",
            "Bash(chmod:*)",
            "Bash(cp:*)",
            "Bash(detect-secrets scan:*)",
            "Bash(docker info:*)",
            "Bash(echo:*)",
            "Bash(file:*)",
            "Bash(find:*)",
            "Bash(gallery-dl:*)",
            "Bash(gh label create:*)",
            "Bash(gh pr *)",
            "Bash(gh pr checks:*)",
            "Bash(gh pr list:*)",
            "Bash(gh pr view:*)",
            "Bash(gh release list:*)",
            "Bash(gh:*)",
            "Bash(git *)",
            "Bash(git add:*)",
            "Bash(git diff:*)",
            "Bash(git log:*)",
            "Bash(git merge-base:*)",
            "Bash(git mv:*)",
            "Bash(git remote get-url:*)",
            "Bash(git tag:*)",
            "Bash(git:*)",
            "Bash(grep:*)",
            "Bash(head:*)",
            "Bash(ls:*)",
            "Bash(make lint:*)",
            "Bash(make markdown-lint:*)",
            "Bash(make verify-structure:*)",
            "Bash(make:*)",
            "Bash(mkdir:*)",
            "Bash(mv:*)",
            "Bash(npm:*)",
            "Bash(pre-commit run:*)",
            "Bash(python3:*)",
            "Bash(rtk:*)",
            "Bash(ruff check:*)",
            "Bash(sort:*)",
            "Bash(tee:*)",
            "Bash(touch:*)",
            "Bash(unzip:*)",
            "Bash(uv --version)",
            "Bash(uv run pytest:*)",
            "Bash(uv run:*)",
            "Bash(uv:*)",
            "Bash(wc:*)",
            "Bash(xargs:*)",
            "Edit",
            "mcp__plugin_telegram__*",
            "Read(//private/tmp/**)",
            "Skill(superpowers:*)",
            "Skill(superpowers:brainstorming)",
            "Skill(superpowers:dispatching-parallel-agents)",
            "Skill(superpowers:test-driven-development)",
            "Skill(superpowers:verification-before-completion)",
            "Skill(superpowers:writing-plans)",
            "WebFetch(domain:docs.astral.sh)",
            "WebFetch(domain:docs.claude.ai)",
            "WebFetch(domain:docs.claude.com)",
            "WebFetch(domain:docs.github.com)",
            "WebFetch(domain:ghcr.io)",
            "WebFetch(domain:github.com)",
            "WebFetch(domain:raw.githubusercontent.com)",
            "WebSearch",
            "Write"
        ],
        "deny": []
    },
    "statusLine": {
        "type": "command",
        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/status_lines/status_line_v10.py",
        "padding": 0
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/pre_tool_use.py"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/post_tool_use.py"
                    }
                ]
            }
        ],
        "Notification": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/notification.py --notify"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/stop.py --chat"
                    }
                ]
            }
        ],
        "SubagentStop": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/subagent_stop.py --notify"
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/user_prompt_submit.py --log-only --store-last-prompt --name-agent"
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/pre_compact.py"
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/session_start.py"
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/session_end.py"
                    }
                ]
            }
        ],
        "PermissionRequest": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/permission_request.py --log-only"
                    }
                ]
            }
        ],
        "PostToolUseFailure": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/post_tool_use_failure.py"
                    }
                ]
            }
        ],
        "SubagentStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/subagent_start.py"
                    }
                ]
            }
        ],
        "Setup": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run $CLAUDE_PROJECT_DIR/.claude/hooks/setup.py"
                    }
                ]
            }
        ]
    },
    "enabledPlugins": {
        "superpowers@claude-plugins-official": true,
        "code-review@claude-plugins-official": true,
        "skill-creator@claude-plugins-official": true,
        "claude-code-setup@claude-plugins-official": true,
        "frontend-design@claude-plugins-official": true,
        "context7@claude-plugins-official": true,
        "code-simplifier@claude-plugins-official": true,
        "playwright@claude-plugins-official": true,
        "claude-md-management@claude-plugins-official": true,
        "code-documentation@claude-code-workflows": true,
        "documentation-generation@claude-code-workflows": true,
        "c4-architecture@claude-code-workflows": true,
        "documentation-standards@claude-code-workflows": true
     }
}
